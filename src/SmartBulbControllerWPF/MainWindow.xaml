<mah:MetroWindow x:Class="SmartBulbControllerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmartBulbControllerWPF.ViewModels"
        xmlns:converters="clr-namespace:SmartBulbControllerWPF.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Smart Bulb Controller" Height="660" Width="900"
        WindowStartupLocation="CenterScreen">

    <!-- Menu bar -->
    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Menu Background="Transparent" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                  xmlns:models="clr-namespace:SmartBulbControllerWPF.Models">
                <MenuItem Header="_File">
                    <MenuItem Header="_Exit" Command="{Binding ExitCommand}" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Theme">
                        <MenuItem Header="_System Default"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static models:ThemePreference.System}" />
                        <MenuItem Header="_Light"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static models:ThemePreference.Light}" />
                        <MenuItem Header="_Dark"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static models:ThemePreference.Dark}" />
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About" Command="{Binding ShowAboutCommand}" />
                </MenuItem>
            </Menu>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: device + preset panels -->
            <Grid Grid.Column="0" Margin="12 12 0 12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- Devices -->
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="DEVICES"
                               Style="{StaticResource MahApps.Styles.TextBlock}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0 0 0 6" />

                    <Button DockPanel.Dock="Bottom"
                            Content="Scan Network"
                            Command="{Binding ScanCommand}"
                            Style="{StaticResource MahApps.Styles.Button}"
                            Margin="0 6 0 0" />

                    <ListBox ItemsSource="{Binding DiscoveredDevices}"
                             SelectedItem="{Binding SelectedDevice}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Ip}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DeviceId}" FontSize="11" Opacity="0.6"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Connect" Command="{Binding ConnectCommand}" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </DockPanel>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />

                <!-- Presets -->
                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="PRESETS"
                               Style="{StaticResource MahApps.Styles.TextBlock}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0 4 0 6" />

                    <!-- Preset action buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0 4 0 0">
                        <Button Content="Apply"
                                Command="{Binding ApplyPresetCommand}"
                                Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                Margin="0 0 0 4" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Delete"
                                    Command="{Binding DeletePresetCommand}"
                                    Style="{StaticResource MahApps.Styles.Button}"
                                    Margin="4 0 0 0" />
                            <Button Content="Save Current"
                                    Command="{Binding SavePresetCommand}"
                                    Style="{StaticResource MahApps.Styles.Button}" />
                        </DockPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Presets}"
                             SelectedItem="{Binding SelectedPreset}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Margin="4 2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="False">
                                                    <Setter Property="FontStyle" Value="Italic" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" />

            <!-- Right: control panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16 12">

                    <!-- Connection status + actions -->
                    <DockPanel Margin="0 0 0 16">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Connect"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                    Margin="0 0 8 0" />
                            <Button Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    Style="{StaticResource MahApps.Styles.Button}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Margin="0 0 8 0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#da3633" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="#3fb950" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Power toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <TextBlock Text="Power" VerticalAlignment="Center" FontSize="14"
                                   Margin="0 0 16 0" />
                        <mah:ToggleSwitch IsOn="{Binding IsOn, Mode=TwoWay}"
                                          IsEnabled="{Binding IsConnected}"
                                          OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <!-- Light controls (disabled when not connected) -->
                    <StackPanel IsEnabled="{Binding IsConnected}">

                        <!-- Mode toggle -->
                        <DockPanel Margin="0 0 0 16">
                            <TextBlock Text="Mode" VerticalAlignment="Center" Width="120"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="White" IsChecked="{Binding IsWhiteMode}"
                                             GroupName="LightMode" Margin="0 0 16 0" />
                                <RadioButton Content="Color" GroupName="LightMode"
                                             IsChecked="{Binding IsWhiteMode, Mode=TwoWay,
                                                 Converter={StaticResource InverseBoolConverter}}" />
                            </StackPanel>
                        </DockPanel>

                        <!-- Brightness (always visible) -->
                        <DockPanel Margin="0 0 0 12">
                            <TextBlock DockPanel.Dock="Left" Text="Brightness"
                                       VerticalAlignment="Center" Width="120" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding Brightness, StringFormat={}{0}%}"
                                       VerticalAlignment="Center" Width="40"
                                       TextAlignment="Right" />
                            <Slider Value="{Binding Brightness, Mode=TwoWay}"
                                    Minimum="0" Maximum="100" TickFrequency="1"
                                    IsSnapToTickEnabled="True" />
                        </DockPanel>

                        <!-- White mode: color temperature -->
                        <DockPanel Margin="0 0 0 12"
                                   Visibility="{Binding IsWhiteMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock DockPanel.Dock="Left" Text="Color Temp"
                                       VerticalAlignment="Center" Width="120" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding ColorTemperature, StringFormat={}{0}%}"
                                       VerticalAlignment="Center" Width="40"
                                       TextAlignment="Right" />
                            <Slider Value="{Binding ColorTemperature, Mode=TwoWay}"
                                    Minimum="0" Maximum="100" TickFrequency="1"
                                    IsSnapToTickEnabled="True" />
                        </DockPanel>

                        <!-- Color mode: RGB sliders + hex -->
                        <StackPanel Margin="0 0 0 0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWhiteMode}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Red -->
                            <DockPanel Margin="0 0 0 8">
                                <TextBlock DockPanel.Dock="Left" Text="Red"
                                           VerticalAlignment="Center" Width="120" Foreground="#f85149" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding ColorRed}"
                                           VerticalAlignment="Center" Width="40"
                                           TextAlignment="Right" />
                                <Slider Value="{Binding ColorRed, Mode=TwoWay}"
                                        Minimum="0" Maximum="255" TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <!-- Green -->
                            <DockPanel Margin="0 0 0 8">
                                <TextBlock DockPanel.Dock="Left" Text="Green"
                                           VerticalAlignment="Center" Width="120" Foreground="#3fb950" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding ColorGreen}"
                                           VerticalAlignment="Center" Width="40"
                                           TextAlignment="Right" />
                                <Slider Value="{Binding ColorGreen, Mode=TwoWay}"
                                        Minimum="0" Maximum="255" TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <!-- Blue -->
                            <DockPanel Margin="0 0 0 8">
                                <TextBlock DockPanel.Dock="Left" Text="Blue"
                                           VerticalAlignment="Center" Width="120" Foreground="#58a6ff" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding ColorBlue}"
                                           VerticalAlignment="Center" Width="40"
                                           TextAlignment="Right" />
                                <Slider Value="{Binding ColorBlue, Mode=TwoWay}"
                                        Minimum="0" Maximum="255" TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <!-- Hex input + color preview -->
                            <DockPanel Margin="0 0 0 0">
                                <TextBlock DockPanel.Dock="Left" Text="Hex"
                                           VerticalAlignment="Center" Width="120" />
                                <Border DockPanel.Dock="Right" Width="32" Height="24"
                                        CornerRadius="3" Margin="8 0 0 0">
                                    <Border.Background>
                                        <SolidColorBrush>
                                            <SolidColorBrush.Color>
                                                <MultiBinding>
                                                    <MultiBinding.Converter>
                                                        <converters:RgbToColorConverter />
                                                    </MultiBinding.Converter>
                                                    <Binding Path="ColorRed" />
                                                    <Binding Path="ColorGreen" />
                                                    <Binding Path="ColorBlue" />
                                                </MultiBinding>
                                            </SolidColorBrush.Color>
                                        </SolidColorBrush>
                                    </Border.Background>
                                </Border>
                                <TextBox Text="{Binding HexColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         mah:TextBoxHelper.Watermark="#RRGGBB"
                                         FontFamily="Consolas" />
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>

                    <!-- NBA Game Alerts -->
                    <Separator Margin="0 16 0 12" />
                    <TextBlock Text="NBA GAME ALERTS"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0 0 0 10" />

                    <DockPanel Margin="0 0 0 10">
                        <TextBlock DockPanel.Dock="Left" Text="Enable Alerts"
                                   VerticalAlignment="Center" Width="120" />
                        <mah:ToggleSwitch IsOn="{Binding AlertEnabled, Mode=TwoWay}"
                                          OnContent="On" OffContent="Off" />
                    </DockPanel>

                    <DockPanel Margin="0 0 0 8">
                        <TextBlock DockPanel.Dock="Left" Text="Team"
                                   VerticalAlignment="Center" Width="120" />
                        <ComboBox ItemsSource="{Binding NbaTeams}"
                                  SelectedItem="{Binding SelectedNbaTeam, Mode=TwoWay}"
                                  DisplayMemberPath="Name" />
                    </DockPanel>

                    <DockPanel Margin="0 0 0 8">
                        <TextBlock DockPanel.Dock="Left" Text="Alert Before (min)"
                                   VerticalAlignment="Center" Width="120" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding AlertLeadMinutes, StringFormat={}{0} min}"
                                   VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                        <Slider Value="{Binding AlertLeadMinutes, Mode=TwoWay}"
                                Minimum="1" Maximum="60" TickFrequency="1"
                                IsSnapToTickEnabled="True" />
                    </DockPanel>

                    <DockPanel Margin="0 0 0 8">
                        <TextBlock DockPanel.Dock="Left" Text="Revert After (hr)"
                                   VerticalAlignment="Center" Width="120" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding AlertRevertHours, StringFormat={}{0} hr}"
                                   VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                        <Slider Value="{Binding AlertRevertHours, Mode=TwoWay}"
                                Minimum="1" Maximum="6" TickFrequency="1"
                                IsSnapToTickEnabled="True" />
                    </DockPanel>

                    <DockPanel Margin="0 0 0 8">
                        <TextBlock DockPanel.Dock="Left" Text="Alert Brightness"
                                   VerticalAlignment="Center" Width="120" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding AlertBrightness, StringFormat={}{0}%}"
                                   VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                        <Slider Value="{Binding AlertBrightness, Mode=TwoWay}"
                                Minimum="10" Maximum="100" TickFrequency="1"
                                IsSnapToTickEnabled="True" />
                    </DockPanel>

                    <!-- Error message -->
                    <Border Background="#2d0f10" BorderBrush="#da3633" BorderThickness="1"
                            CornerRadius="4" Padding="10 6" Margin="0 16 0 0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#f85149"
                                   TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <!-- Busy indicator -->
                    <mah:ProgressRing Width="40" Height="40"
                                      HorizontalAlignment="Left" Margin="0 12 0 0"
                                      IsActive="{Binding IsBusy}"
                                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
