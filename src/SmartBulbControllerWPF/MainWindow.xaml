<mah:MetroWindow x:Class="SmartBulbControllerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmartBulbControllerWPF.ViewModels"
        xmlns:converters="clr-namespace:SmartBulbControllerWPF.Converters"
        xmlns:views="clr-namespace:SmartBulbControllerWPF.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Smart Bulb Controller" Height="640" Width="820"
        WindowStartupLocation="CenterScreen">

    <!-- Menu bar -->
    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Menu Background="Transparent" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                  xmlns:models="clr-namespace:SmartBulbControllerWPF.Models">
                <MenuItem Header="_File">
                    <MenuItem Header="_Exit" Command="{Binding ExitCommand}" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Theme">
                        <MenuItem Header="_System Default"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static models:ThemePreference.System}" />
                        <MenuItem Header="_Light"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static models:ThemePreference.Light}" />
                        <MenuItem Header="_Dark"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static models:ThemePreference.Dark}" />
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About" Command="{Binding ShowAboutCommand}" />
                </MenuItem>
            </Menu>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: device + preset panels -->
            <Grid Grid.Column="0" Margin="12 12 0 12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- Devices -->
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="DEVICES"
                               Style="{StaticResource MahApps.Styles.TextBlock}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0 0 0 6" />

                    <Button DockPanel.Dock="Bottom"
                            Content="Scan Network"
                            Command="{Binding ScanCommand}"
                            Style="{StaticResource MahApps.Styles.Button}"
                            Margin="0 6 0 0" />

                    <ListBox ItemsSource="{Binding DiscoveredDevices}"
                             SelectedItem="{Binding SelectedDevice}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DeviceId}" FontSize="11" Opacity="0.6"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Connect" Command="{Binding ConnectCommand}" />
                                <MenuItem Header="Rename…"
                                          Command="{Binding RenameDeviceCommand}" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </DockPanel>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />

                <!-- Presets -->
                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="PRESETS"
                               Style="{StaticResource MahApps.Styles.TextBlock}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                               Margin="0 4 0 6" />

                    <!-- Preset action buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0 4 0 0">
                        <Button Content="Apply"
                                Command="{Binding ApplyPresetCommand}"
                                Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                Margin="0 0 0 4" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Delete"
                                    Command="{Binding DeletePresetCommand}"
                                    Style="{StaticResource MahApps.Styles.Button}"
                                    Margin="4 0 0 0" />
                            <Button Content="Save Current"
                                    Command="{Binding SavePresetCommand}"
                                    Style="{StaticResource MahApps.Styles.Button}" />
                        </DockPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Presets}"
                             SelectedItem="{Binding SelectedPreset}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Margin="4 2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="False">
                                                    <Setter Property="FontStyle" Value="Italic" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" />

            <!-- Right: connection bar + tab panels -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Connection bar -->
                <DockPanel Grid.Row="0" Margin="16 10 16 0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <mah:ProgressRing Width="20" Height="20" Margin="0 0 10 0"
                                          IsActive="{Binding IsBusy}"
                                          Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Connect"
                                Command="{Binding ConnectCommand}"
                                Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                Margin="0 0 6 0" />
                        <Button Content="Disconnect"
                                Command="{Binding DisconnectCommand}"
                                Style="{StaticResource MahApps.Styles.Button}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Margin="0 0 8 0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#da3633" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#3fb950" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>

                <!-- Tab control -->
                <TabControl Grid.Row="1" Margin="12 8 12 0"
                            BorderThickness="1"
                            Style="{StaticResource MahApps.Styles.TabControl}">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem" BasedOn="{StaticResource MahApps.Styles.TabItem}">
                            <Setter Property="Padding" Value="20 8" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <!-- Controls tab -->
                    <TabItem Header="Controls">
                        <StackPanel Margin="12 14 12 12">

                            <!-- Power -->
                            <DockPanel Margin="0 0 0 14">
                                <TextBlock DockPanel.Dock="Left" Text="Power"
                                           VerticalAlignment="Center" Width="120" FontSize="14" />
                                <mah:ToggleSwitch IsOn="{Binding IsOn, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsConnected}"
                                                  OnContent="On" OffContent="Off" />
                            </DockPanel>

                            <!-- Light controls -->
                            <StackPanel IsEnabled="{Binding IsConnected}">

                                <!-- Mode -->
                                <DockPanel Margin="0 0 0 14">
                                    <TextBlock DockPanel.Dock="Left" Text="Mode"
                                               VerticalAlignment="Center" Width="120" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="White" IsChecked="{Binding IsWhiteMode}"
                                                     GroupName="LightMode" Margin="0 0 16 0" />
                                        <RadioButton Content="Color" GroupName="LightMode"
                                                     IsChecked="{Binding IsWhiteMode, Mode=TwoWay,
                                                         Converter={StaticResource InverseBoolConverter}}" />
                                    </StackPanel>
                                </DockPanel>

                                <!-- Brightness -->
                                <DockPanel Margin="0 0 0 10">
                                    <TextBlock DockPanel.Dock="Left" Text="Brightness"
                                               VerticalAlignment="Center" Width="120" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Brightness, StringFormat={}{0}%}"
                                               VerticalAlignment="Center" Width="44" TextAlignment="Right" />
                                    <Slider Value="{Binding Brightness, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1"
                                            IsSnapToTickEnabled="True" />
                                </DockPanel>

                                <!-- Color temp (white mode) -->
                                <DockPanel Margin="0 0 0 10"
                                           Visibility="{Binding IsWhiteMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock DockPanel.Dock="Left" Text="Color Temp"
                                               VerticalAlignment="Center" Width="120" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding ColorTemperature, StringFormat={}{0}%}"
                                               VerticalAlignment="Center" Width="44" TextAlignment="Right" />
                                    <Slider Value="{Binding ColorTemperature, Mode=TwoWay}"
                                            Minimum="0" Maximum="100" TickFrequency="1"
                                            IsSnapToTickEnabled="True" />
                                </DockPanel>

                                <!-- RGB + hex + color wheel (color mode) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWhiteMode}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Color wheel -->
                                    <views:ColorWheelPicker
                                        HorizontalAlignment="Center"
                                        Margin="0 4 0 12"
                                        Hue="{Binding ColorHue, Mode=TwoWay}"
                                        Saturation="{Binding ColorSaturation, Mode=TwoWay}" />

                                    <DockPanel Margin="0 0 0 8">
                                        <TextBlock DockPanel.Dock="Left" Text="Red"
                                                   VerticalAlignment="Center" Width="120" Foreground="#f85149" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ColorRed}"
                                                   VerticalAlignment="Center" Width="44" TextAlignment="Right" />
                                        <Slider Value="{Binding ColorRed, Mode=TwoWay}"
                                                Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" />
                                    </DockPanel>

                                    <DockPanel Margin="0 0 0 8">
                                        <TextBlock DockPanel.Dock="Left" Text="Green"
                                                   VerticalAlignment="Center" Width="120" Foreground="#3fb950" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ColorGreen}"
                                                   VerticalAlignment="Center" Width="44" TextAlignment="Right" />
                                        <Slider Value="{Binding ColorGreen, Mode=TwoWay}"
                                                Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" />
                                    </DockPanel>

                                    <DockPanel Margin="0 0 0 8">
                                        <TextBlock DockPanel.Dock="Left" Text="Blue"
                                                   VerticalAlignment="Center" Width="120" Foreground="#58a6ff" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding ColorBlue}"
                                                   VerticalAlignment="Center" Width="44" TextAlignment="Right" />
                                        <Slider Value="{Binding ColorBlue, Mode=TwoWay}"
                                                Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" />
                                    </DockPanel>

                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="Hex"
                                                   VerticalAlignment="Center" Width="120" />
                                        <Border DockPanel.Dock="Right" Width="32" Height="24"
                                                CornerRadius="3" Margin="8 0 0 0">
                                            <Border.Background>
                                                <SolidColorBrush>
                                                    <SolidColorBrush.Color>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <converters:RgbToColorConverter />
                                                            </MultiBinding.Converter>
                                                            <Binding Path="ColorRed" />
                                                            <Binding Path="ColorGreen" />
                                                            <Binding Path="ColorBlue" />
                                                        </MultiBinding>
                                                    </SolidColorBrush.Color>
                                                </SolidColorBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBox Text="{Binding HexColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 mah:TextBoxHelper.Watermark="#RRGGBB"
                                                 FontFamily="Consolas" />
                                    </DockPanel>
                                </StackPanel>

                                <!-- Animated scenes -->
                                <Separator Margin="0 12 0 8" />
                                <TextBlock Text="ANIMATED SCENES"
                                           FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                                           Margin="0 0 0 8" />
                                <StackPanel IsEnabled="{Binding IsConnected}">
                                    <UniformGrid Columns="4" Margin="0 0 0 8"
                                                 xmlns:models="clr-namespace:SmartBulbControllerWPF.Models">
                                        <ToggleButton Content="Color Cycle" Margin="0 0 4 0" Padding="6 4"
                                                      IsChecked="{Binding IsColorCycleActive, Mode=OneWay}"
                                                      Command="{Binding SetSceneCommand}"
                                                      CommandParameter="{x:Static models:SceneType.ColorCycle}" />
                                        <ToggleButton Content="Pulse" Margin="0 0 4 0" Padding="6 4"
                                                      IsChecked="{Binding IsPulseActive, Mode=OneWay}"
                                                      Command="{Binding SetSceneCommand}"
                                                      CommandParameter="{x:Static models:SceneType.Pulse}" />
                                        <ToggleButton Content="Strobe" Margin="0 0 4 0" Padding="6 4"
                                                      IsChecked="{Binding IsStrobeActive, Mode=OneWay}"
                                                      Command="{Binding SetSceneCommand}"
                                                      CommandParameter="{x:Static models:SceneType.Strobe}" />
                                        <ToggleButton Content="Stop" Padding="6 4"
                                                      Command="{Binding SetSceneCommand}"
                                                      CommandParameter="{x:Static models:SceneType.None}" />
                                    </UniformGrid>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="Step Delay"
                                                   VerticalAlignment="Center" Width="120" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding SceneStepMs, StringFormat={}{0} ms}"
                                                   VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                                        <Slider Value="{Binding SceneStepMs, Mode=TwoWay}"
                                                Minimum="30" Maximum="400"
                                                TickFrequency="10" IsSnapToTickEnabled="True" />
                                    </DockPanel>
                                </StackPanel>

                            </StackPanel>
                        </StackPanel>
                    </TabItem>

                    <!-- Alerts tab -->
                    <TabItem Header="Alerts">
                        <StackPanel Margin="12 14 12 12">

                            <DockPanel Margin="0 0 0 14">
                                <TextBlock DockPanel.Dock="Left" Text="Enable Alerts"
                                           VerticalAlignment="Center" Width="130" />
                                <mah:ToggleSwitch IsOn="{Binding AlertEnabled, Mode=TwoWay}"
                                                  OnContent="On" OffContent="Off" />
                            </DockPanel>

                            <DockPanel Margin="0 0 0 10">
                                <TextBlock DockPanel.Dock="Left" Text="Team"
                                           VerticalAlignment="Center" Width="130" />
                                <Border DockPanel.Dock="Right" Width="22" Height="22"
                                        CornerRadius="3" Margin="6 0 0 0" VerticalAlignment="Center"
                                        Background="{Binding AlertTeamColorHex, Converter={StaticResource HexToBrushConverter}}" />
                                <ComboBox ItemsSource="{Binding NbaTeams}"
                                          SelectedItem="{Binding SelectedNbaTeam, Mode=TwoWay}"
                                          DisplayMemberPath="Name" />
                            </DockPanel>

                            <DockPanel Margin="0 0 0 10">
                                <TextBlock DockPanel.Dock="Left" Text="Next Game"
                                           VerticalAlignment="Center" Width="130" Opacity="0.7" />
                                <TextBlock Text="{Binding NextGameText}"
                                           VerticalAlignment="Center" FontSize="12" Opacity="0.85" />
                            </DockPanel>

                            <DockPanel Margin="0 0 0 10">
                                <TextBlock DockPanel.Dock="Left" Text="Alert Before"
                                           VerticalAlignment="Center" Width="130" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AlertLeadMinutes, StringFormat={}{0} min}"
                                           VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                                <Slider Value="{Binding AlertLeadMinutes, Mode=TwoWay}"
                                        Minimum="1" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <DockPanel Margin="0 0 0 10">
                                <TextBlock DockPanel.Dock="Left" Text="Revert After"
                                           VerticalAlignment="Center" Width="130" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AlertRevertHours, StringFormat={}{0} hr}"
                                           VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                                <Slider Value="{Binding AlertRevertHours, Mode=TwoWay}"
                                        Minimum="1" Maximum="6" TickFrequency="1" IsSnapToTickEnabled="True" />
                            </DockPanel>

                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Alert Brightness"
                                           VerticalAlignment="Center" Width="130" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AlertBrightness, StringFormat={}{0}%}"
                                           VerticalAlignment="Center" Width="50" TextAlignment="Right" />
                                <Slider Value="{Binding AlertBrightness, Mode=TwoWay}"
                                        Minimum="10" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" />
                            </DockPanel>

                        </StackPanel>
                    </TabItem>

                    <!-- Settings tab -->
                    <TabItem Header="Settings">
                        <StackPanel Margin="12 14 12 12">

                            <DockPanel Margin="0 0 0 16">
                                <TextBlock DockPanel.Dock="Left" Text="Launch on Startup"
                                           VerticalAlignment="Center" Width="130" />
                                <mah:ToggleSwitch IsOn="{Binding LaunchOnStartup, Mode=TwoWay}"
                                                  OnContent="On" OffContent="Off" />
                            </DockPanel>

                            <DockPanel Margin="0 0 0 10">
                                <TextBlock DockPanel.Dock="Left" Text="Saved Device"
                                           VerticalAlignment="Center" Width="130" />
                                <Button Content="Clear"
                                        Command="{Binding ClearSavedDeviceCommand}"
                                        Style="{StaticResource MahApps.Styles.Button}"
                                        HorizontalAlignment="Left" />
                            </DockPanel>

                            <Separator Margin="0 10 0 10" />

                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Version"
                                           VerticalAlignment="Center" Width="130" Opacity="0.6" />
                                <TextBlock Text="{Binding AppVersion}"
                                           VerticalAlignment="Center" Opacity="0.6" />
                            </DockPanel>

                        </StackPanel>
                    </TabItem>

                </TabControl>

                <!-- Error message -->
                <Border Grid.Row="2"
                        Background="#2d0f10" BorderBrush="#da3633" BorderThickness="1"
                        CornerRadius="4" Padding="10 6" Margin="12 6 12 6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#f85149"
                               TextWrapping="Wrap" FontSize="12" />
                </Border>

            </Grid>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
