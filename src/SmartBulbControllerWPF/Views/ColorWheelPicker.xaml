<UserControl x:Class="SmartBulbControllerWPF.Views.ColorWheelPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180" Height="180">
    <Canvas x:Name="WheelCanvas" Width="180" Height="180" Cursor="Crosshair"
            MouseDown="OnMouseDown" MouseMove="OnMouseMove" MouseUp="OnMouseUp">
        <Image x:Name="WheelImage" Width="180" Height="180" IsHitTestVisible="False" />
        <!-- Outer shadow ring -->
        <Ellipse x:Name="SelectorOuter" Width="16" Height="16"
                 Stroke="Black" StrokeThickness="2" Fill="Transparent"
                 IsHitTestVisible="False" Opacity="0.6" />
        <!-- Inner white indicator -->
        <Ellipse x:Name="SelectorInner" Width="14" Height="14"
                 Stroke="White" StrokeThickness="2" Fill="Transparent"
                 IsHitTestVisible="False" />
    </Canvas>
</UserControl>
